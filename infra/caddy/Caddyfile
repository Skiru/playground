{
    auto_https off
    frankenphp
}

{$SERVER_NAME::80} {
    root * /app/public
    encode zstd gzip
    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
        -Server
    }
    php_server
}
