APP_ENV=dev
APP_SECRET=replace-with-a-random-local-value
POSTGRES_DB=family_places
POSTGRES_USER=family_places
POSTGRES_PASSWORD=replace-with-a-random-local-value
DATABASE_URL=postgresql://family_places:replace-with-a-random-local-value@database:5432/family_places?serverVersion=18&charset=utf8
MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
MAP_ATTRIBUTION=MapLibre demonstration tiles
MAP_PROVIDER_NAME=MapLibre Demo Tiles
API_BASE_URL=http://api
GOOGLE_IDENTITY_ENABLED=false
PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
DEV_AUTH_ENABLED=true

# Media Storage Configuration
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=/data/familyplaces-media
# In production, MEDIA_PUBLIC_BASE_URL must be a public URL accessible from the user's browser (e.g., https://yourdomain.com/media)
MEDIA_PUBLIC_BASE_URL=http://localhost:8080/media
