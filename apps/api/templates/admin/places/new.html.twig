{% extends 'admin/layout.html.twig' %}

{% block title %}Nowe miejsce | FamilyPlaces Admin{% endblock %}

{% block content_title %}
    <ol class="breadcrumb mb-1 fs-6">
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_places') }}">Miejsca</a></li>
        <li class="breadcrumb-item active text-dark">Nowe miejsce</li>
    </ol>
    <h1 class="m-0 fs-2 fw-bold text-dark">Nowe miejsce</h1>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('admin_places') }}" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left me-1"></i> Anuluj
    </a>
{% endblock %}

{% block main %}
    <div class="container-fluid p-0">
        {% include 'admin/places/_form.html.twig' with {submitLabel: 'Utwórz cały draft'} %}
    </div>
    {% include 'admin/places/_form_script.html.twig' %}
{% endblock %}
