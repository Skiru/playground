{% extends 'base.html.twig' %}
{% block title %}{{ place.name }} | FamilyPlaces Admin{% endblock %}
{% block body %}
<main>
    <nav><a href="{{ path('admin_places') }}">Miejsca</a> · <a href="{{ path('admin_places_edit', {id: place.id}) }}">Edytuj</a></nav>
    <h1>{{ place.name }}</h1>
    <section aria-label="Workflow">{% for action in ['submit','publish','unpublish','reverify','close','archive'] %}<form method="post" action="{{ path('admin_places_action', {id: place.id, action: action}) }}" style="display:inline"><input type="hidden" name="_token" value="{{ csrf_token('place-' ~ place.id) }}"><input type="hidden" name="version" value="{{ place.version }}"><button>{{ action }}</button></form>{% endfor %}</section>
    <dl>
        <dt>Status</dt><dd>{{ place.status.value }}</dd><dt>Wersja</dt><dd>{{ place.version }}</dd>
        <dt>Slug</dt><dd>{{ place.slug }}</dd><dt>Miasto</dt><dd>{{ place.city.name }}</dd>
        <dt>Adres</dt><dd>{{ place.addressLine1 }} {{ place.addressLine2 }}; {{ place.postalCode }}</dd>
        <dt>Współrzędne</dt><dd>{{ place.coordinates.latitude }}, {{ place.coordinates.longitude }}</dd>
        <dt>Timezone</dt><dd>{{ place.timezone }}</dd><dt>Weryfikacja</dt><dd>{{ place.verificationStatus.value }}</dd>
    </dl>
    <h2>Opis</h2><p>{{ place.shortDescription }}</p><p>{{ place.description }}</p>
    <h2>Kategorie</h2><ul>{% for category in place.categories %}<li>{{ category.name }}{% if category.id == place.primaryCategory.id %} (primary){% endif %}</li>{% endfor %}</ul>
    <h2>Udogodnienia</h2><ul>{% for amenity in place.amenities %}<li>{{ amenity.name }}</li>{% else %}<li>Brak</li>{% endfor %}</ul>
    <h2>Strefy wieku</h2><ul>{% for zone in place.ageZones %}<li>{{ zone.name }}: {{ zone.ageRange.minAgeMonths }}–{{ zone.ageRange.maxAgeMonths ?? 'bez limitu' }}</li>{% else %}<li>Brak</li>{% endfor %}</ul>
    <h2>Godziny tygodniowe</h2><ul>{% for interval in place.weeklyOpeningHours %}<li>{{ interval.weekday }}. {{ interval.opensAt|date('H:i') }}–{{ interval.closesAt|date('H:i') }}{% if interval.closesNextDay %} (+1){% endif %}</li>{% else %}<li>Brak</li>{% endfor %}</ul>
    <h2>Dni specjalne</h2><ul>{% for day in place.specialOpeningDays %}<li>{{ day.localDate|date('Y-m-d') }}: {{ day.closed ? 'zamknięte' : 'otwarte' }}</li>{% else %}<li>Brak</li>{% endfor %}</ul>
    <h2>Referencje zewnętrzne</h2><ul>{% for reference in place.externalReferences %}<li>{{ reference.provider }}: {{ reference.externalId }}</li>{% else %}<li>Brak</li>{% endfor %}</ul>

    <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #ccd0d5;">

    <h2>Media & Galeria</h2>
    <div style="background:#f0f4f8; padding:1.5rem; border-radius:8px; border:1px solid #ccd0d5; margin-bottom:2rem;">
        <h3 style="margin-top:0">Dodaj zdjęcia</h3>
        <form method="post" enctype="multipart/form-data" action="{{ path('admin_places_photos_upload', {id: place.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('place-photos-' ~ place.id) }}">
            <div style="margin-bottom:1rem">
                <input type="file" name="photos[]" multiple accept="image/*" required>
            </div>
            <button type="submit" style="background:#0056b3; color:#fff; border:0; padding:0.5rem 1rem; border-radius:4px; font-weight:bold; cursor:pointer">Prześlij zdjęcia</button>
        </form>
    </div>

    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:1.5rem; margin-bottom: 3rem;">
        {% for photo in place.photos %}
            <div style="border:1px solid #ccd0d5; border-radius:8px; padding:1rem; background:#fff; display:flex; flex-direction:column; gap:0.5rem; position:relative;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem">
                    <span style="font-weight:bold; font-size:0.85rem">Zdjęcie ({{ photo.status }})</span>
                    {% if photo.main %}
                        <span style="background:#28a745; color:#fff; font-size:0.75rem; padding:0.2rem 0.4rem; border-radius:4px; font-weight:bold;">GŁÓWNE</span>
                    {% endif %}
                </div>
                
                {% if photo.status == 'completed' and photo.variants.thumbnail is defined %}
                    <img src="{{ photo.variants.thumbnail }}" alt="{{ photo.altText ?? 'Zdjęcie' }}" style="width:100%; height:160px; object-fit:cover; border-radius:4px; margin-bottom:0.5rem" />
                {% else %}
                    <div style="width:100%; height:160px; background:#e9ecef; display:flex; align-items:center; justify-content:center; border-radius:4px; margin-bottom:0.5rem; color:#6c757d; font-size:0.9rem">
                        {% if photo.status == 'processing' %}
                            Przetwarzanie...
                        {% elseif photo.status == 'failed' %}
                            Błąd przetwarzania
                        {% else %}
                            Brak podglądu
                        {% endif %}
                    </div>
                {% endif %}

                <p style="font-size:0.75rem; color:#6c757d; margin:0 0 0.5rem 0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="{{ photo.originalFilename }}">Plik: {{ photo.originalFilename }}</p>

                <form method="post" action="{{ path('admin_places_photos_update', {id: place.id, photoId: photo.id.toRfc4122}) }}" style="display:grid; gap:0.4rem; margin-bottom:0.5rem">
                    <input type="hidden" name="_token" value="{{ csrf_token('place-photo-ops-' ~ photo.id.toRfc4122) }}">
                    <div>
                        <label style="font-size:0.75rem; font-weight:bold; display:block">Alt Text</label>
                        <input type="text" name="alt_text" value="{{ photo.altText }}" style="width:100%; padding:0.25rem; font-size:0.8rem">
                    </div>
                    <div>
                        <label style="font-size:0.75rem; font-weight:bold; display:block">Podpis (Caption)</label>
                        <input type="text" name="caption" value="{{ photo.caption }}" style="width:100%; padding:0.25rem; font-size:0.8rem">
                    </div>
                    <div>
                        <label style="font-size:0.75rem; font-weight:bold; display:block">Kolejność (Display Order)</label>
                        <input type="number" name="display_order" value="{{ photo.displayOrder }}" style="width:60px; padding:0.25rem; font-size:0.8rem">
                    </div>
                    <button type="submit" style="background:#6c757d; color:#fff; border:0; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.8rem; cursor:pointer; align-self:start">Zapisz szczegóły</button>
                </form>

                <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:auto; border-top:1px solid #eee; padding-top:0.5rem">
                    {% if not photo.main and photo.status == 'completed' %}
                        <form method="post" action="{{ path('admin_places_photos_set_main', {id: place.id, photoId: photo.id.toRfc4122}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('place-photo-ops-' ~ photo.id.toRfc4122) }}">
                            <button type="submit" style="background:#007bff; color:#fff; border:0; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.8rem; cursor:pointer">Ustaw jako główne</button>
                        </form>
                    {% endif %}
                    
                    <form method="post" action="{{ path('admin_places_photos_reprocess', {id: place.id, photoId: photo.id.toRfc4122}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('place-photo-ops-' ~ photo.id.toRfc4122) }}">
                        <button type="submit" style="background:#ffc107; color:#000; border:0; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.8rem; cursor:pointer">Przetwórz ponownie</button>
                    </form>

                    <form method="post" action="{{ path('admin_places_photos_delete', {id: place.id, photoId: photo.id.toRfc4122}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('place-photo-ops-' ~ photo.id.toRfc4122) }}">
                        <button type="submit" style="background:#dc3545; color:#fff; border:0; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.8rem; cursor:pointer" onclick="return confirm('Czy na pewno chcesz usunąć to zdjęcie?')">Usuń</button>
                    </form>
                </div>
            </div>
        {% else %}
            <p style="grid-column: 1/-1; text-align:center; color:#6c757d; font-style:italic">Brak zdjęć w galerii.</p>
        {% endfor %}
    </div>
</main>
{% endblock %}
