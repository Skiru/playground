{% form_theme form 'bootstrap_5_layout.html.twig' %}

{{ form_start(form, {attr: {class: 'place-admin-form', novalidate: 'novalidate'}}) }}
    {% if not form.vars.valid %}
        <div class="alert alert-danger" role="alert" tabindex="-1">
            {{ form_errors(form) }}
        </div>
    {% endif %}
    
    {{ form_widget(form.expectedVersion) }}

    <div class="row g-4">
        <div class="col-lg-6">
            <fieldset class="card p-4 shadow-sm mb-4 h-100 bg-white">
                <legend class="card-title h5 mb-3 text-primary fw-bold"><i class="fa fa-info-circle me-1"></i> Dane podstawowe</legend>
                {{ form_widget(form.core) }}
            </fieldset>
        </div>

        <div class="col-lg-6">
            <fieldset class="card p-4 shadow-sm mb-4 h-100 bg-white">
                <legend class="card-title h5 mb-3 text-primary fw-bold"><i class="fa fa-tags me-1"></i> Klasyfikacja</legend>
                
                <div class="mb-3">
                    <label for="category-filter" class="form-label small fw-bold">Filtruj kategorie</label>
                    <input id="category-filter" type="search" data-choice-filter="{{ form.categorySlugs.vars.id }}" autocomplete="off" class="form-control form-control-sm" placeholder="Szukaj kategorii...">
                </div>
                {{ form_row(form.categorySlugs) }}
                {{ form_row(form.primaryCategorySlug) }}
                
                <div class="mb-3 mt-4">
                    <label for="amenity-filter" class="form-label small fw-bold">Filtruj udogodnienia</label>
                    <input id="amenity-filter" type="search" data-choice-filter="{{ form.amenitySlugs.vars.id }}" autocomplete="off" class="form-control form-control-sm" placeholder="Szukaj udogodnień...">
                </div>
                {{ form_row(form.amenitySlugs) }}
            </fieldset>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <fieldset class="card p-4 shadow-sm mb-4 bg-white">
                <legend class="card-title h5 mb-3 text-primary fw-bold"><i class="fa fa-child me-1"></i> Strefy wieku</legend>
                {{ form_row(form.ageZones) }}
            </fieldset>
        </div>

        <div class="col-lg-6">
            <fieldset class="card p-4 shadow-sm mb-4 bg-white">
                <legend class="card-title h5 mb-3 text-primary fw-bold"><i class="fa fa-clock me-1"></i> Godziny otwarcia</legend>
                {{ form_row(form.openingHoursMode) }}
                {{ form_row(form.weeklyOpeningHours) }}
            </fieldset>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <fieldset class="card p-4 shadow-sm mb-4 bg-white">
                <legend class="card-title h5 mb-3 text-primary fw-bold"><i class="fa fa-calendar-day me-1"></i> Dni specjalne</legend>
                {{ form_row(form.specialOpeningDays) }}
            </fieldset>
        </div>

        <div class="col-lg-6">
            <fieldset class="card p-4 shadow-sm mb-4 bg-white">
                <legend class="card-title h5 mb-3 text-primary fw-bold"><i class="fa fa-link me-1"></i> Referencje zewnętrzne</legend>
                {{ form_row(form.externalReferences) }}
            </fieldset>
        </div>
    </div>

    <!-- Sticky action bar -->
    <div class="sticky-page-actions shadow-sm border rounded p-3 bg-white d-flex gap-2 justify-content-end align-items-center mt-4">
        {% if placeId is defined %}
            <a href="{{ path('admin_places_view', {id: placeId}) }}" class="btn btn-outline-secondary">Anuluj</a>
        {% else %}
            <a href="{{ path('admin_places') }}" class="btn btn-outline-secondary">Anuluj</a>
        {% endif %}
        <button type="submit" class="btn btn-primary px-4 fw-bold">{{ submitLabel }}</button>
    </div>
{{ form_end(form) }}
