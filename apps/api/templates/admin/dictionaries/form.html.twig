{% extends 'base.html.twig' %}
{% block title %}{{ item ? 'Edytuj' : 'Dodaj' }} {{ type }} | FamilyPlaces Admin{% endblock %}
{% block body %}<main><a href="{{ path('admin_dictionary_list', {type: type}) }}">Anuluj</a><h1>{{ item ? 'Edytuj' : 'Dodaj' }} {{ type }}</h1>
{% for message in app.flashes('error') %}<p role="alert">{{ message }}</p>{% endfor %}<form method="post"><input type="hidden" name="_token" value="{{ csrf_token(item ? 'dictionary-' ~ type ~ '-' ~ item.id : 'dictionary-' ~ type) }}">
<label>Nazwa <input name="name" value="{{ item.name ?? '' }}" required maxlength="120"></label><label>Slug <input name="slug" value="{{ item.slug ?? '' }}" pattern="[a-z0-9-]+" required maxlength="120"></label><label><input type="checkbox" name="enabled" value="1"{% if item is null or item.enabled %} checked{% endif %}> Aktywne</label>
{% if type == 'cities' %}<label>Kod kraju <input name="countryCode" value="{{ item.country_code ?? 'PL' }}" pattern="[A-Z]{2}" required></label><label>Latitude <input name="latitude" type="number" min="-90" max="90" step="any" value="{{ item.latitude ?? '' }}" required></label><label>Longitude <input name="longitude" type="number" min="-180" max="180" step="any" value="{{ item.longitude ?? '' }}" required></label><label>Zoom <input name="defaultZoom" type="number" min="1" max="20" value="{{ item.default_zoom ?? 12 }}"></label><label>Promień km <input name="defaultRadiusKm" type="number" min="1" max="100" value="{{ item.default_radius_km ?? 15 }}"></label><label>Timezone <input name="timezone" value="{{ item.timezone ?? 'Europe/Warsaw' }}" required></label>
{% else %}<label>Ikona <input name="iconKey" value="{{ item.icon_key ?? '' }}" required></label><label>Kolejność <input name="displayOrder" type="number" min="0" value="{{ item.display_order ?? 0 }}" required></label>{% if type == 'categories' %}<label>Opis <textarea name="description">{{ item.description ?? '' }}</textarea></label>{% else %}<label>Grupa <input name="group" value="{{ item.amenity_group ?? '' }}" required></label>{% endif %}{% endif %}<button>Zapisz</button></form></main>{% endblock %}
