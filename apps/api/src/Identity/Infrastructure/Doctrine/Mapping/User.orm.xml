<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Identity\Domain\User" table="users">
        <id name="id" type="uuid" column="id" />
        <field name="email" column="email" type="string" unique="true" />
        <field name="displayName" column="display_name" type="string" />
        <field name="passwordHash" column="password_hash" type="string" nullable="true" />
        <field name="googleSubject" column="google_subject" type="string" nullable="true" unique="true" />
        <field name="roles" column="roles" type="json" />
        <field name="status" column="status" type="string" enum-type="App\Identity\Domain\UserStatus" />
        <field name="createdAt" column="created_at" type="datetime_immutable" />
        <field name="updatedAt" column="updated_at" type="datetime_immutable" />
        <field name="lastLoginAt" column="last_login_at" type="datetime_immutable" nullable="true" />
    </entity>
</doctrine-mapping>
