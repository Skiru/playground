#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_dir"

if [ ! -f .env ]; then
    cp .env.example .env
    printf '%s\n' 'Created .env from .env.example; replace local secrets before shared use.'
fi

docker run --rm -u "$(id -u):$(id -g)" -e HOME=/tmp -v "$repo_dir:/workspace" -w /workspace node:24-bookworm sh -c 'corepack pnpm install --frozen-lockfile'
docker compose -f compose.yaml -f compose.dev.yaml build
