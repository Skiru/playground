#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_dir"

if [ "$#" -lt 1 ]; then
  echo "Usage: $0 <backup-file-path>"
  exit 1
fi

backup_file="$1"
echo "Starting restore from $backup_file..."

# 1. Verify checksum if a checksum file is present next to the backup file
checksum_file="$backup_file.sha256"
if [ -f "$checksum_file" ]; then
  echo "Verifying backup file checksum..."
  sha256sum -c "$checksum_file"
  echo "✓ Checksum matches."
else
  echo "Warning: Checksum file not found. Skipping validation."
fi

target_restore_file="$backup_file"
temp_decrypted=""

# 2. Decrypt if needed
if [ "${backup_file##*.}" = "enc" ]; then
  if [ -z "${BACKUP_PASSPHRASE:-}" ]; then
    echo "Error: Backup is encrypted, but BACKUP_PASSPHRASE is not set!"
    exit 1
  fi
  echo "Decrypting backup file..."
  temp_decrypted="${backup_file%.enc}.dec"
  openssl enc -d -aes-256-cbc -pbkdf2 -pass "pass:$BACKUP_PASSPHRASE" -in "$backup_file" -out "$temp_decrypted"
  target_restore_file="$temp_decrypted"
fi

# 3. Terminate active connections and clean DB
echo "Disconnecting active connections and dropping public schema..."
docker compose -f compose.yaml -f compose.test.yaml exec -T database psql -U family_places_test -d family_places_test -c "
  SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = 'family_places_test' AND pid <> pg_backend_pid();
  DROP SCHEMA public CASCADE;
  CREATE SCHEMA public;
  GRANT ALL ON SCHEMA public TO family_places_test;
  GRANT ALL ON SCHEMA public TO public;
" > /dev/null

# 4. Restore using pg_restore
echo "Executing pg_restore into database..."
docker compose -f compose.yaml -f compose.test.yaml exec -T database pg_restore -U family_places_test --no-owner --role=family_places_test -d family_places_test < "$target_restore_file"

# Cleanup decrypted temp file
if [ -n "$temp_decrypted" ] && [ -f "$temp_decrypted" ]; then
  rm "$temp_decrypted"
fi

echo "✓ Restore completed successfully."
